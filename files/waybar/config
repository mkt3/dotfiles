{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "spacing": 0, // Gaps between modules (4px)
    "modules-left": ["wlr/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["custom/vpn", "custom/pacman", "cpu", "memory", "pulseaudio", "backlight", "battery", "clock", "tray", "idle_inhibitor"],
    // Modules configuration
    "wlr/workspaces": {
        "all-outputs": true,
        "format": "{name} {icon}",
        "format-icons": {
            "1:main": "яДа",
            "2:slack": "яБ╡",
            "3:discord": "яБ╡",           
            "8:game": "яДЫ",
            "9:sub": "яДа",
            "10:media": "яАБ",
            "urgent": "яБк",
            "active": "яЖТ",
            "default": "яДС"
        }
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        "icon-size": 24,
        "spacing": 2
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%Y-%m-%d(%a) %H:%M}",
        "format-alt": "{:%Y-%m-%d(%a) %H:%M}"
    },
    "cpu": {
        "format": "яЛЫ {usage}% LA:{load}",
        "tooltip": false
    },
    "memory": {
        "format": "яГЙ {used:0.1f}G/{total:0.1f}G({percentage}%)"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            "full": 100,
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "яКФ  {icon} {volume}% {format_source}",
        "format-bluetooth-muted": "яКФ  яЪй  {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/vpn": {
        "format": "яВм {}",
        "interval": 5,
        "exec": "$HOME/.config/waybar/scripts/nm-vpn.sh",
        "exec-if": "exit 0"
     },
    "custom/pacman": {
        "format": "яМГ {}",
        "interval": 3600,
        "exec": "checkupdates | wc -l | sed -E 's/^0$//g'",
        "exec-if": "exit 0",
        "on-click": "wezterm start -- yay; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "min-length": 4
    },
}
